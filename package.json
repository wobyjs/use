{
  "name": "@woby/use",
  "repository": "https://github.com/wobyjs/use.git",
  "description": "@woby/use",
  "version": "0.0.30",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/ssr/index.ssr.cjs.js",
  "module": "./dist/browser/index.browser.es.js",
  "types": "./dist/browser/types/index.d.ts",
  "sass": "./dist/styles.scss",
  "sideEffects": false,
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/types/index.d.ts",
        "import": "./dist/browser/index.browser.es.js",
        "require": "./dist/browser/index.browser.umd.js"
      },
      "ssr": {
        "types": "./dist/ssr/types/index.ssr.d.ts",
        "import": "./dist/ssr/index.ssr.js",
        "require": "./dist/ssr/index.ssr.cjs"
      },
      "default": {
        "types": "./dist/ssr/types/index.ssr.d.ts",
        "default": "./dist/ssr/index.ssr.cjs"
      }
    },
    "./browser": {
      "types": "./dist/browser/types/index.d.ts",
      "import": "./dist/browser/index.browser.es.js",
      "require": "./dist/browser/index.browser.umd.js"
    },
    "./ssr": {
      "types": "./dist/ssr/types/index.ssr.d.ts",
      "import": "./dist/ssr/index.ssr.js",
      "require": "./dist/ssr/index.ssr.cjs"
    }
  },
  "keywords": [
    "ui",
    "framework",
    "reactive",
    "react"
  ],
  "dependencies": {
    "nanoid": "^5.0.9",
    "typescript": "5.7.3"
  },
  "devDependencies": {
    "@woby/chk": "workspace:../chk",
    "@woby/vite-plugin-test": "workspace:../vite-plugin-test",
    "cross-env": "^7.0.3",
    "vite": "^6.1.0",
    "vite-plugin-tsconfig": "^2.0.0"
  },
  "peerDependencies": {
    "woby": "workspace:../woby"
  },
  "scripts": {
    "bump": "pnpm version patch --no-git-tag-version",
    "push": "git push && git push --tags",
    "npmjs": "pnpm publish --access public",
    "commit": "pnpm git && pnpm bump && pnpm push",
    "release": "run-s -c commit npmjs",
    "build:test": "cross-env NODE_ENV=test && vite build --config vite.config.test.mts",
    "build:test:watch": "cross-env NODE_ENV=test && vite build --config vite.config.test.mts --watch",
    "watch:test": "cross-env NODE_ENV=test && vite --config=vite.config.test.mts --force --host --mode dev",
    "watch:prod": "cross-env NODE_ENV=production && vite --config=vite.config.test.mts --force --host --mode production",
    "test": "pnpm run build:test && chk",
    "test:watch": "pnpm run build:test && chk-watch",
    "build:web": "vite build --config=vite.config.web.mts --force --mode production",
    "web": "vite preview --config=vite.config.web.mts --host",
    "dev": "vite --config=vite.config.web.mts --force --mode dev --host",
    "prod": "vite --force",
    "declaration": "tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --declarationMap",
    "declaration:watch": "tsc -p tsconfig.build.json --declaration --emitDeclarationOnly --declarationMap--watch",
    "build:only": "vite build",
    "watch:only": "vite build --watch",
    "watch": "run-s watch:only declaration:watch",
    "build": "run-s build:clean build:browser build:ssr build:types",
    "build:browser": "vite build --config vite.config.browser.mts",
    "build:ssr": "vite build --config vite.config.ssr.mts",
    "build:types": "run-p build:types:browser build:types:ssr",
    "build:types:browser": "tsc -p tsconfig.browser.json",
    "build:types:ssr": "tsc -p tsconfig.ssr.json",
    "build:clean": "rimraf dist",
    "build:tsc": "rimraf dist && tsc -p tsconfig.build.json",
    "clean": "rimraf ./dist/",
    "prepublishOnly1": "pnpm run clean && pnpm run build",
    "release:automatic": "semantic-release --extends ../semantic-release.config.js",
    "commit:help": "echo 'Usage: pnpm run commit' && echo 'This will start the commitizen wizard to create a conventional commit.' && echo 'Follow the prompts to enter commit type, scope, and message.'"
  }
}