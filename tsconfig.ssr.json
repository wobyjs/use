{
    "extends": "./tsconfig.build.json",
    "compilerOptions": {
        "lib": [
            "dom",
            "esnext"
        ],
        "outDir": "./dist/ssr/",
        "declarationDir": "./dist/ssr/types/",
        "noEmit": false,
        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": [
        "src/index.ssr.tsx",
        "src/use/**/*",
        "src/utils.tsx",
        "src/Array/**/*",
        "src/Object.tsx",
        "src/Ratio/**/*",
        "src/useBoolean/**/*",
        "src/useCounter/**/*",
        "src/useMap/**/*",
        "src/useSet/**/*",
        "src/useStep/**/*",
        "src/useToggle/**/*",
        "src/useInvert/**/*",
        "src/useDestruct/**/*",
        "src/useDebounce/**/*",
        "src/useTimeout/**/*",
        "src/useInterval/**/*",
        "src/useTimer/**/*",
        "src/usePause/**/*",
        "src/useEventCallback/**/*",
        "src/useIsomorphicLayoutEffect/**/*",
        "src/useId/**/*",
        "src/useWith/**/*",
        "src/useTry/**/*",
        "src/useSsr/**/*"
    ],
    "exclude": [
        "node_modules/*",
        "**/*.test.ts*",
        "**/*.spec.ts*",
        "**/*.xtest.ts",
        "vite.*.*ts",
        "demo",
        "dist",
        "**/*.demo.ts*",
        "**/tests.ts",
        "**/test.tsx",
        "test",
        // Exclude browser-only hooks
        "src/useLocalStorage/**/*",
        "src/useSessionStorage/**/*",
        "src/useCopyToClipboard/**/*",
        "src/useEventListener/**/*",
        "src/useClickAway*",
        "src/useClickAnyWhere/**/*",
        "src/useOnClickOutside/**/*",
        "src/useHover/**/*",
        "src/useElementSize/**/*",
        "src/useWindowSize/**/*",
        "src/useComputedStyle*",
        "src/useLocation*",
        "src/useGpsLocation/**/*",
        "src/useScreen/**/*",
        "src/useScreenOrientation*",
        "src/useMediaQuery/**/*",
        "src/useIntersectionObserver/**/*",
        "src/useDocumentTitle/**/*",
        "src/useLockedBody/**/*",
        "src/useScript/**/*",
        "src/useImageOnLoad/**/*",
        "src/useDarkMode/**/*",
        "src/useTernaryDarkMode/**/*",
        "src/useFetch/**/*",
        "src/useSelection*",
        "src/isLocalhost*"
    ]
}